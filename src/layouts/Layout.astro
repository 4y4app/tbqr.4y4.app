---
import AdSidebar from "../components/AdSidebar.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Thunderbirdのメールアカウント設定をQRコードで作成し、モバイル版Thunderbirdへ簡単に設定できるWebツールです。IMAP/POP3/SMTPに対応。" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL("/og-image.png", Astro.site).href;

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "WebApplication",
	name: "Thunderbird QR",
	url: Astro.site?.href,
	description,
	applicationCategory: "UtilitiesApplication",
	operatingSystem: "Any",
	offers: {
		"@type": "Offer",
		price: "0",
		priceCurrency: "JPY",
	},
};
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />

        <!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
        <meta name="keywords" content="Thunderbird, QRコード, 設定, 移行, モバイル, エクスポート, アカウント設定, メール設定, サンダーバード" />
        <link rel="canonical" href={canonicalURL} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:site_name" content="Thunderbird QR" />
        <meta property="og:locale" content="ja_JP" />

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={ogImageURL} />

        <!-- Robots -->
        <meta name="robots" content="index, follow" />

        <!-- 構造化データ -->
        <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@600;700;800;900&family=Inter:wght@400;500;600;700&family=Fira+Code:wght@400;500&display=swap"
            rel="stylesheet"
        />

		<!-- QRコード生成ライブラリ (CDN) -->
		<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
	</head>
	<body class="flex min-h-screen flex-col bg-slate-50 text-slate-900 antialiased">
		<div class="mx-auto flex w-full max-w-5xl flex-1 flex-col gap-8 px-6 pt-28 pb-16">
			<div class="rounded-[2rem] border border-slate-200/60 bg-white p-8 shadow-sm">
				<slot />
			</div>
			<AdSidebar />
		</div>
		<Footer />
	</body>
</html>

<style is:global>
	/* フォーム共通スタイル */
	form {
		display: flex;
		flex-direction: column;
		gap: 1.5em;
		text-align: left;
	}

	fieldset {
		border: 1px solid var(--color-slate-200);
		border-radius: 1rem;
		padding: 1.5em;
		margin: 0;
		background-color: var(--color-slate-50);
	}

	legend {
		font-weight: 700;
		color: var(--color-brand-700);
		padding: 0 0.5em;
		background-color: #fff;
		border: 1px solid var(--color-slate-200);
		border-radius: 0.5rem;
		font-size: 0.9em;
	}

	label {
		display: block;
		margin-bottom: 0.5em;
		font-weight: 500;
		color: var(--color-slate-500);
		font-size: 0.9em;
		margin-top: 1em;
	}
	label:first-of-type {
		margin-top: 0;
	}

	input[type=text],
	input[type=email],
	input[type=password],
	select {
		width: 100%;
		padding: 10px 12px;
		border: 1px solid var(--color-slate-200);
		border-radius: 0.75rem;
		font-size: 1em;
		font-family: var(--font-sans);
		box-sizing: border-box;
		background-color: #fff;
		color: var(--color-slate-900);
		transition: border-color 0.2s, box-shadow 0.2s;
	}

	input[type=text]:focus,
	input[type=email]:focus,
	input[type=password]:focus,
	select:focus {
		outline: none;
		border-color: var(--color-brand-500);
		box-shadow: 0 0 0 3px var(--color-brand-100);
	}
</style>
